@startuml Fittrack_Workout_Flow
title Fittrack - Workout Start And Logging Flow

skinparam shadowing false

actor User
participant "Shared Layout /\nCommand Bar" as Layout
participant "WorkoutPlanLive" as PlanLive
participant "WorkoutLive" as WorkoutLive
participant "Training context" as Training
participant "Repo" as Repo

User -> Layout : Start empty workout or Start from plan

alt Start from plan
  Layout -> PlanLive : Navigate to plans
  User -> PlanLive : Start from plan
  PlanLive -> Training : create_workout_from_plan(current_scope, plan_id)
else Start empty workout
  Layout -> WorkoutLive : Navigate to /workouts/new
  WorkoutLive -> Training : create_workout(current_scope, attrs)
end

Training -> Repo : Insert workout session
Repo --> Training : Workout
Training --> WorkoutLive : Active workout

User -> WorkoutLive : Log performed set
WorkoutLive -> Training : create_workout_set(current_scope, workout, attrs)
Training -> Repo : Insert performed set
Repo --> WorkoutLive : WorkoutSet
@enduml

@startuml Fittrack_Nutrition_Import_Flow
title Fittrack - Nutrition Import Review Flow

skinparam shadowing false

actor User
participant "MealLive.Form" as MealLive
participant "Nutrition context" as Nutrition
participant "External parser/API" as External
participant "Repo" as Repo

User -> MealLive : Import barcode, URL, or screenshot
MealLive -> Nutrition : lookup/import request
Nutrition -> External : Fetch or parse nutrition data
External --> Nutrition : Parsed food attributes
Nutrition --> MealLive : Review payload
MealLive --> User : Confirmation panel + import status

alt Save to meal
  User -> MealLive : Save to meal
  MealLive -> Nutrition : build_meal_item(attrs)
else Save to library
  User -> MealLive : Save to library
  MealLive -> Nutrition : create_food(current_scope, attrs)
  Nutrition -> Repo : Insert food with source metadata
end
@enduml

