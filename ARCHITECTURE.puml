' Fittrack architecture diagrams.
' Render with PlantUML, or import into Astah via a PlantUML-compatible workflow.
' Legacy SparkyFitness runtime footprint has been removed; SparkyFitness is not
' part of the current FitTrack architecture.

@startuml Fittrack_System_Context
title Fittrack - System Context

skinparam componentStyle rectangle
skinparam shadowing false

actor "Authenticated user" as User
actor "Public visitor" as Visitor
actor "Operator" as Operator
node "Web browser" as Browser
component "Fittrack Phoenix app\nLiveView + controllers + Mix tasks" as App
database "PostgreSQL database\nmetadata + source of truth" as DB
folder "EXERCISE_MEDIA_STORAGE_ROOT\napp-owned exercise media files" as MediaStorage
cloud "WGER API\nexercise templates + media records" as WGER
cloud "WGER media URLs\nremote image/video references" as WGERMedia
cloud "Open Food Facts API" as OFF
cloud "Supported dining/menu pages" as Dining
cloud "OpenAI image parser" as OpenAI

User --> Browser
Visitor --> Browser
Browser --> App : HTTP / LiveView websocket
Browser --> App : GET /exercise-media/:id
Operator --> App : mix fittrack.backfill_exercise_media

App --> DB : Ecto metadata queries
App --> MediaStorage : read/write cached media files
App --> WGER : Fetch exercise/media catalog via Req
App --> WGERMedia : Validate/download media via Req
App --> OFF : Barcode lookup via Req
App --> Dining : Nutrition URL import via Req
App --> OpenAI : Screenshot nutrition extraction

note right of DB
PostgreSQL stores exercise templates,
normalized library metadata, sources,
and exercise_media rows.

Media binaries are not stored in DB.
end note

note right of MediaStorage
Files live on disk under
EXERCISE_MEDIA_STORAGE_ROOT.

exercise_media.local_path and
exercise_media.storage_key are
relative paths only.
end note
@enduml

@startuml Fittrack_Phoenix_Containers
title Fittrack - Phoenix Container Architecture

skinparam componentStyle rectangle
skinparam shadowing false

actor "Browser" as Browser
actor "Operator" as Operator
cloud "WGER API / media URLs" as WGER
folder "EXERCISE_MEDIA_STORAGE_ROOT" as MediaStorage

package "fittrack_web" {
  component "Router" as Router
  component "UserAuth\nplugs + LiveView on_mount" as Auth
  component "Layouts + CoreComponents" as Layouts
  component "DashboardLive" as DashboardLive
  component "WorkoutLive\nWorkoutHistoryLive" as WorkoutLive
  component "WorkoutPlanLive" as WorkoutPlanLive
  component "ExerciseLibraryLive\n/exercises" as ExerciseLibraryLive
  component "ExerciseLibraryDetailLive\n/exercises/:slug" as ExerciseLibraryDetailLive
  component "AdminExerciseLibraryLive\n/admin/exercises" as AdminExerciseLibraryLive
  component "ExerciseLive\n/my-exercises CRUD" as ExerciseLive
  component "ExerciseTemplateImageController\n/exercise-media/:id\nfallback media" as MediaController
  component "NutritionLive" as NutritionLive
  component "MealLive\nFoodLive\nMealPlanLive" as MealLive
  component "assets/js app.js hooks" as AppJS
}

package "fittrack contexts" {
  component "Accounts" as Accounts
  component "Training context" as Training
  component "Nutrition" as Nutrition
}

package "Exercise media import/cache" {
  component "Fittrack.Training.Wger.MediaClient" as WgerMediaClient
  component "Fittrack.Training.ExerciseMediaBackfill" as Backfill
  component "MediaValidator" as MediaValidator
  component "ExerciseMediaCache" as ExerciseMediaCache
}

package "Persistence" {
  component "Fittrack.Repo" as Repo
  database "PostgreSQL tables\nexercise_media metadata" as Tables
}

Browser --> Router : HTTP routes + LiveView websocket
Router --> Auth
Router --> MediaController
Auth --> DashboardLive
Auth --> WorkoutLive
Auth --> WorkoutPlanLive
Auth --> ExerciseLive
Auth --> AdminExerciseLibraryLive
Auth --> NutritionLive
Auth --> MealLive
Router --> ExerciseLibraryLive
Router --> ExerciseLibraryDetailLive

DashboardLive --> Layouts
WorkoutLive --> Layouts
WorkoutPlanLive --> Layouts
ExerciseLibraryLive --> Layouts
ExerciseLibraryDetailLive --> Layouts
AdminExerciseLibraryLive --> Layouts
ExerciseLive --> Layouts
NutritionLive --> Layouts
MealLive --> Layouts
Layouts --> AppJS

ExerciseLibraryLive --> Training
ExerciseLibraryDetailLive --> Training
AdminExerciseLibraryLive --> Training
ExerciseLive --> Training
WorkoutLive --> Training
WorkoutPlanLive --> Training
MediaController --> Training : load ExerciseMedia metadata
MediaController --> MediaStorage : send_file cached media
NutritionLive --> Nutrition
MealLive --> Nutrition
Router --> Accounts

Operator --> Backfill : mix task
Backfill --> WgerMediaClient : fetch media records
WgerMediaClient --> WGER : Req API requests
Backfill --> Training : match/upsert templates + media
Backfill --> MediaValidator : validate URL/content
MediaValidator --> WGER : HEAD/GET remote media metadata
Backfill --> ExerciseMediaCache : cache valid media
