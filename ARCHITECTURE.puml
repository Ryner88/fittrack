@startuml Fittrack_Workout_Flow
title Fittrack - Workout Start And Logging Flow

skinparam shadowing false

actor User
participant "Shared Layout /\nCommand Bar" as Layout
participant "WorkoutPlanLive" as PlanLive
participant "WorkoutLive" as WorkoutLive
participant "Training context" as Training
participant "Repo" as Repo

User -> Layout : Start empty workout or Start from plan

alt Start from plan
  Layout -> PlanLive : Navigate to plans
  User -> PlanLive : Start from plan
  PlanLive -> Training : create_workout_from_plan(current_scope, plan_id)
else Start empty workout
  Layout -> WorkoutLive : Navigate to /workouts/new
  WorkoutLive -> Training : create_workout(current_scope, attrs)
end

Training -> Repo : Insert workout session
Repo --> Training : Workout
Training --> WorkoutLive : Active workout

User -> WorkoutLive : Log performed set
WorkoutLive -> Training : create_workout_set(current_scope, workout, attrs)
Training -> Repo : Insert performed set
Repo --> WorkoutLive : WorkoutSet
@enduml

@startuml Fittrack_Exercise_Media_Backfill_Flow
title Fittrack - Exercise Media Backfill Flow

skinparam shadowing false

actor Operator
participant "mix fittrack.backfill_exercise_media" as MixTask
participant "ExerciseMediaBackfill" as Backfill
participant "WGER MediaClient" as MediaClient
participant "WGER API / media URLs" as WGER
participant "Training context" as Training
participant "MediaValidator" as Validator
participant "ExerciseMediaCache" as Cache
database "PostgreSQL\nexercise_media metadata" as DB
collections "EXERCISE_MEDIA_STORAGE_ROOT\n<exercise_template_id>/<sha256>.<extension>" as MediaStorage

Operator -> MixTask : Run backfill task
MixTask -> MixTask : Load env\nEXERCISE_MEDIA_STORAGE_ROOT
MixTask -> Backfill : run(opts)
Backfill -> MediaClient : fetch_media(limit, media_type, api_key)
MediaClient -> WGER : Fetch WGER media records
WGER --> MediaClient : image/video media records
MediaClient --> Backfill : records

Backfill -> Backfill : Task.async_stream\nbounded concurrency\n(default 3)

loop per media record
  Backfill -> Training : find_template_for_wger_media(record)
  alt template matched
    Backfill -> Validator : validate_url(source_url)
    Validator -> WGER : Validate URL/content
    alt valid media
      Backfill -> Training : upsert initial exercise_media
      Training -> DB : Insert/update metadata
      Backfill -> Cache : cache(media)
      Cache -> WGER : Download bytes
      Cache -> MediaStorage : Write file
      Cache --> Backfill : relative local_path/storage_key
      Backfill -> Training : update exercise_media cached fields
      Training -> DB : Store relative paths + metadata only
    else missing/skipped/stale/failed
      Backfill -> Training : mark cache_status + failure_reason
      Training -> DB : Update metadata only
    end
  else no template or unsupported input
    Backfill -> Backfill : Count missing/skipped/failed
  end
end

Backfill --> MixTask : Report counts
MixTask --> Operator : fetched, cached, already_cached,\nmissing, skipped, stale, failed,\nexercises_with_no_media

note right of DB
No media bytes are stored in PostgreSQL.
local_path and storage_key are relative paths.
end note
@enduml

@startuml Fittrack_Public_Exercise_Media_Serving_Flow
title Fittrack - Public Exercise Media Serving Flow

skinparam shadowing false

actor Browser
participant "Router" as Router
participant "ExerciseTemplateImageController" as Controller
participant "Training context" as Training
database "PostgreSQL\nexercise_media metadata" as DB
collections "EXERCISE_MEDIA_STORAGE_ROOT" as MediaStorage

Browser -> Router : GET /exercise-media/:id
Router -> Controller : media(conn, id)
Controller -> Training : get_exercise_media(id)
Training -> DB : Load ExerciseMedia metadata
DB --> Training : metadata row
Training --> Controller : ExerciseMedia
Controller -> Training : exercise_media_path(media)
Training -> MediaStorage : Check cached file path

alt cached file exists
  MediaStorage --> Training : absolute file path
  Training --> Controller : {:ok, path}
  Controller --> Browser : send_file 200\ncontent-type = media.mime_type
else missing, non-cached, invalid id, or read error
  Training --> Controller : {:error, reason} or nil
  Controller --> Browser : Safe SVG fallback\nimage/svg+xml
end

note right of DB
DB stores metadata only.
Media binaries are served from disk
under EXERCISE_MEDIA_STORAGE_ROOT.
end note
@enduml

@startuml Fittrack_Nutrition_Import_Flow
title Fittrack - Nutrition Import Review Flow

skinparam shadowing false

actor User
participant "MealLive.Form" as MealLive
participant "Nutrition context" as Nutrition
participant "External parser/API" as External
participant "Repo" as Repo

User -> MealLive : Import barcode, URL, or screenshot
MealLive -> Nutrition : lookup/import request
Nutrition -> External : Fetch or parse nutrition data
External --> Nutrition : Parsed food attributes
Nutrition --> MealLive : Review payload
MealLive --> User : Confirmation panel + import status

alt Save to meal
  User -> MealLive : Save to meal
  MealLive -> Nutrition : build_meal_item(attrs)
else Save to library
  User -> MealLive : Save to library
  MealLive -> Nutrition : create_food(current_scope, attrs)
  Nutrition -> Repo : Insert food with source metadata
end
@enduml

